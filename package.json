{
  "name": "alif-digest",
  "version": "1.0.8",
  "description": "Autonomous AI Signal Digest CLI for tracking high-signal AI breakthroughs.",
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "bin": {
    "alif": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/cli/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "dev": "tsx src/cli/index.ts",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,js,mjs,json,md}": [
      "prettier --write",
      "eslint --fix"
    ]
  },
  "keywords": [
    "ai",
    "cli",
    "digest",
    "newsletter",
    "automation",
    "ollama",
    "anthropic",
    "signal"
  ],
  "author": "qaribhaider",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.13.6",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.2.0",
    "commander": "^14.0.3",
    "dotenv": "^17.3.1",
    "ollama": "^0.6.3",
    "openai": "^6.26.0",
    "prompts": "^2.4.2",
    "rss-parser": "^3.13.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.3.3",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "eslint": "^10.0.2",
    "globals": "^17.4.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "vitest": "^4.0.18"
  }
}
